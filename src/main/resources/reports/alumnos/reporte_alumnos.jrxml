<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="reporte_alumnos"
	pageWidth="595"
	pageHeight="842"
	columnWidth="555"
	leftMargin="20"
	rightMargin="20"
	topMargin="20"
	bottomMargin="20">

	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SistemaNotasDB"/>

	<!-- 🔥 LOGO CORREGIDO -->
	<parameter name="LOGO" class="java.io.InputStream"/>

	<queryString>
		<![CDATA[
		SELECT apellidos, codigo, correo, direccion, telefono, nombres, id
		FROM sistema_notas_db.alumno
		]]>
	</queryString>

	<field name="apellidos" class="java.lang.String"/>
	<field name="codigo" class="java.lang.String"/>
	<field name="correo" class="java.lang.String"/>
	<field name="direccion" class="java.lang.String"/>
	<field name="telefono" class="java.lang.String"/>
	<field name="nombres" class="java.lang.String"/>
	<field name="id" class="java.lang.Long"/>

	<title>
		<band height="102">

			<image>
				<reportElement x="227" y="0" width="100" height="100"/>
				<imageExpression><![CDATA[$P{LOGO}]]></imageExpression>
			</image>

			<staticText>
				<reportElement x="219" y="30" width="200" height="30"/>
				<text><![CDATA[REPORTE DE ALUMNOS]]></text>
			</staticText>

		</band>
	</title>

	<columnHeader>
		<band height="30">
			<staticText><reportElement x="0" y="0" width="50" height="30"/><text><![CDATA[id]]></text></staticText>
			<staticText><reportElement x="50" y="0" width="60" height="30"/><text><![CDATA[codigo]]></text></staticText>
			<staticText><reportElement x="110" y="0" width="100" height="30"/><text><![CDATA[nombres]]></text></staticText>
			<staticText><reportElement x="210" y="0" width="120" height="30"/><text><![CDATA[apellidos]]></text></staticText>
			<staticText><reportElement x="330" y="0" width="100" height="30"/><text><![CDATA[correo]]></text></staticText>
			<staticText><reportElement x="430" y="0" width="120" height="30"/><text><![CDATA[direccion]]></text></staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="30">

			<textField>
				<reportElement x="0" y="0" width="50" height="30"/>
				<textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="50" y="0" width="60" height="30"/>
				<textFieldExpression><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="110" y="0" width="100" height="30"/>
				<textFieldExpression><![CDATA[$F{nombres}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="210" y="0" width="120" height="30"/>
				<textFieldExpression><![CDATA[$F{apellidos}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="330" y="0" width="100" height="30"/>
				<textFieldExpression><![CDATA[$F{correo}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="430" y="0" width="120" height="30"/>
				<textFieldExpression><![CDATA[$F{direccion}]]></textFieldExpression>
			</textField>

		</band>
	</detail>

</jasperReport>